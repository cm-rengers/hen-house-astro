---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import GalleryMosaic from '../components/GalleryMosaic.astro';
import WhyStay from '../components/WhyStay.astro';
import Facilities from '../components/Facilities.astro';
import LocationSection from '../components/LocationSection.astro';
import BookingSection from '../components/BookingSection.astro';
import FAQ from '../components/FAQ.astro';
---

<BaseLayout title="The Hen House – Boutique countryside retreat in Cumbria">
  <Header />
  <main>
    <Hero />
    <GalleryMosaic />
    <WhyStay />
    <Facilities />
    <LocationSection />
    <BookingSection />
    <FAQ />
  </main>
</BaseLayout>
