---
import { getCollection, render } from 'astro:content';
import { getImage } from 'astro:assets';
import type { GetStaticPaths } from 'astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import BlogCTA from '../../components/blog/BlogCTA.astro';
import FAQAccordion from '../../components/blog/FAQAccordion.astro';
import RelatedPosts from '../../components/blog/RelatedPosts.astro';
import BlogSidebar from '../../components/blog/BlogSidebar.astro';

function toSlug(id: string): string {
  return id.replace(/\.(md|mdx)$/, '');
}

export const getStaticPaths: GetStaticPaths = async () => {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { slug: post.id.replace(/\.(md|mdx)$/, '') },
    props: { post },
  }));
};

function estimateReadingTime(body: string): number {
  const words = body.trim().split(/\s+/).filter(Boolean).length;
  return Math.max(1, Math.ceil(words / 200));
}

const { post } = Astro.props;
const { Content } = await render(post);
const readingTime = estimateReadingTime(post.body ?? '');
const allPosts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime());
const readingTimes = Object.fromEntries(allPosts.map((entry) => [toSlug(entry.id), estimateReadingTime(entry.body ?? '')]));

const {
  title,
  description,
  publishDate,
  updatedDate,
  heroImage,
  heroImageAlt,
  tags,
  faqs,
  canonicalUrl,
  ogImage,
} = post.data;

const formattedDate = publishDate.toLocaleDateString('en-GB', {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
});
const postUrl = canonicalUrl ?? new URL(Astro.url.pathname, Astro.url.origin).href;
const resolvedOgImage = await getImage({
  src: ogImage ?? heroImage,
  width: 1200,
  height: 630,
  format: 'webp',
});
const ogImageUrl = new URL(resolvedOgImage.src, Astro.url.origin).href;
const modifiedDate = updatedDate ?? publishDate;

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: title,
  description,
  image: ogImageUrl,
  datePublished: publishDate.toISOString(),
  dateModified: modifiedDate.toISOString(),
  author: {
    '@type': 'Organization',
    name: 'The Hen House',
    url: Astro.url.origin,
  },
  publisher: {
    '@type': 'Organization',
    name: 'The Hen House Cumbria',
    url: Astro.url.origin,
  },
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id': postUrl,
  },
};

const faqSchema = faqs?.length
  ? {
      '@context': 'https://schema.org',
      '@type': 'FAQPage',
      mainEntity: faqs.map((faq) => ({
        '@type': 'Question',
        name: faq.question,
        acceptedAnswer: {
          '@type': 'Answer',
          text: faq.answer,
        },
      })),
    }
  : null;

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: Astro.url.origin },
    { '@type': 'ListItem', position: 2, name: 'Journal', item: new URL('/blog', Astro.url.origin).href },
    { '@type': 'ListItem', position: 3, name: title, item: postUrl },
  ],
};
---

<BaseLayout title={`${title} - The Hen House Cumbria`} description={description} ogImage={resolvedOgImage.src}>
  <Fragment slot="head">
    <link rel="canonical" href={postUrl} />
    <meta property="og:type" content="article" />
    <meta property="og:url" content={postUrl} />
    <meta property="og:image:alt" content={heroImageAlt} />
    <meta property="article:published_time" content={publishDate.toISOString()} />
    <meta property="article:modified_time" content={modifiedDate.toISOString()} />
    {tags.map((tag) => <meta property="article:tag" content={tag} />)}
    <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
    {faqSchema && <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />}
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  </Fragment>

  <Header />
  <main>
    <nav class="blog-breadcrumb blog-container" aria-label="Breadcrumb">
      <a href="/">Home</a>
      <span aria-hidden="true">/</span>
      <a href="/blog">Journal</a>
      <span aria-hidden="true">/</span>
      <span aria-current="page">{title}</span>
    </nav>

    <header class="blog-post-hero">
      <div class="blog-container blog-post-hero-grid">
        <div class="blog-post-hero-copy">
          <p class="blog-meta">
            <time datetime={publishDate.toISOString()}>{formattedDate}</time>
            <span aria-hidden="true">/</span>
            <span>{readingTime} min read</span>
          </p>
          <h1>{title}</h1>
          <p>{description}</p>
          {tags.length > 0 && (
            <ul class="blog-tags" aria-label="Tags">
              {tags.map((tag) => <li><a href={`/blog?tag=${encodeURIComponent(tag)}`}>{tag}</a></li>)}
            </ul>
          )}
        </div>
        <div class="blog-post-hero-image">
          <img src={resolvedOgImage.src} alt={heroImageAlt} loading="eager" />
        </div>
      </div>
    </header>

    <div class="blog-container blog-article-shell">
      <article class="blog-prose">
        <Content />
        {faqs && faqs.length > 0 && <FAQAccordion faqs={faqs} />}
        <BlogCTA
          headline="Thinking of visiting Cumbria?"
          subheading="The Hen House is dog-friendly, EV-ready and just minutes from the M6. Check availability for your dates."
        />
      </article>
      <BlogSidebar allPosts={allPosts} currentSlug={toSlug(post.id)} />
    </div>

    <RelatedPosts currentPost={post} allPosts={allPosts} readingTimes={readingTimes} />
    <BlogCTA />
  </main>
</BaseLayout>
