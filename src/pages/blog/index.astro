---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import FeaturedPost from '../../components/blog/FeaturedPost.astro';
import BlogCard from '../../components/blog/BlogCard.astro';
import BlogCTA from '../../components/blog/BlogCTA.astro';

function estimateReadingTime(body: string): number {
  const words = body.trim().split(/\s+/).filter(Boolean).length;
  return Math.max(1, Math.ceil(words / 200));
}

const toSlug = (id: string) => id.replace(/\.(md|mdx)$/, '');
const allPosts = (await getCollection('blog'))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime());

const featuredPost = allPosts.find((post) => post.data.featured) ?? allPosts[0];
const gridPosts = featuredPost ? allPosts.filter((post) => toSlug(post.id) !== toSlug(featuredPost.id)) : allPosts;
const activeTag = Astro.url.searchParams.get('tag');
const displayed = activeTag
  ? gridPosts.filter((post) => post.data.tags.includes(activeTag))
  : gridPosts;
const allTags = [...new Set(allPosts.flatMap((post) => post.data.tags))].sort();
const siteUrl = Astro.url.origin;
const blogUrl = new URL('/blog/', siteUrl).href;
const description = 'Guides, local tips and slow-travel inspiration from The Hen House, a boutique cottage retreat in Cumbria, near the M6 and the Lake District.';

const blogSchema = {
  '@context': 'https://schema.org',
  '@type': 'Blog',
  name: 'The Hen House Blog',
  description,
  url: blogUrl,
  publisher: {
    '@type': 'Organization',
    name: 'The Hen House Cumbria',
    url: siteUrl,
  },
  blogPost: allPosts.map((post) => ({
    '@type': 'BlogPosting',
    headline: post.data.title,
    description: post.data.description,
    datePublished: post.data.publishDate.toISOString(),
    dateModified: (post.data.updatedDate ?? post.data.publishDate).toISOString(),
    url: new URL(`/blog/${toSlug(post.id)}/`, siteUrl).href,
  })),
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: siteUrl },
    { '@type': 'ListItem', position: 2, name: 'Blog', item: blogUrl },
  ],
};
---

<BaseLayout
  title="Blog - The Hen House Cumbria"
  description={description}
  ogTitle="Blog - The Hen House Cumbria"
  ogDescription={description}
>
  <Fragment slot="head">
    <link rel="canonical" href={blogUrl} />
    <link rel="sitemap" type="application/xml" href="/sitemap.xml" />
    <script type="application/ld+json" set:html={JSON.stringify(blogSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  </Fragment>

  <Header />

  <header class="max-w-[1200px] mx-auto px-6 md:px-10 lg:px-14 pt-16 pb-10 md:pt-20 md:pb-12">
    <p class="text-[#6b6b6b] text-[10px] tracking-[0.2em] uppercase mb-3">
      The Hen House
    </p>
    <h1
      class="leading-[1.05]"
      style="
        font-family: 'Cormorant Garamond', Georgia, serif;
        font-weight: 500;
        font-size: clamp(2rem, 5vw, 3.5rem);
        letter-spacing: -0.01em;
      "
    >
      Blog
    </h1>
  </header>

  {featuredPost && (
    <FeaturedPost post={featuredPost} readingTime={estimateReadingTime(featuredPost.body ?? '')} />
  )}

  {allTags.length > 0 && (
    <div class="max-w-[1200px] mx-auto px-6 md:px-10 lg:px-14 pt-12 pb-2">
      <nav aria-label="Filter by topic">
        <ul class="flex flex-wrap gap-2 m-0 p-0 list-none">
          <li>
            <a
              href="/blog"
              class={`inline-block px-4 py-1.5 rounded-full text-[10px] tracking-widest uppercase transition-all duration-200 no-underline ${
                !activeTag
                  ? 'bg-[#1a1a1a] text-white'
                  : 'bg-[#f0ede8] text-[#6b6b6b] hover:bg-[#1a1a1a] hover:text-white'
              }`}
            >
              All
            </a>
          </li>
          {allTags.map((tag) => (
            <li>
              <a
                href={`/blog?tag=${encodeURIComponent(tag)}`}
                class={`inline-block px-4 py-1.5 rounded-full text-[10px] tracking-widest uppercase transition-all duration-200 no-underline ${
                  activeTag === tag
                    ? 'bg-[#1a1a1a] text-white'
                    : 'bg-[#f0ede8] text-[#6b6b6b] hover:bg-[#1a1a1a] hover:text-white'
                }`}
              >
                {tag}
              </a>
            </li>
          ))}
        </ul>
      </nav>
    </div>
  )}

  <main id="main-content" class="max-w-[1200px] mx-auto px-6 md:px-10 lg:px-14 py-10 md:py-14">
    {displayed.length > 0 ? (
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 md:gap-8">
        {displayed.map((post) => (
          <BlogCard post={post} readingTime={estimateReadingTime(post.body ?? '')} />
        ))}
      </div>
    ) : (
      <p class="text-[#6b6b6b] text-sm py-12 text-center">
        No posts found for &ldquo;{activeTag}&rdquo;.
        <a href="/blog" class="underline hover:text-[#1a1a1a]">View all posts</a>
      </p>
    )}
  </main>

  <BlogCTA />
</BaseLayout>
