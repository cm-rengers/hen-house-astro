---
export interface Props {
  images?: { src: string; alt: string }[];
  pageBackground?: string;
}

// Images in public/images/hero — use absolute paths from site root
const defaultImages = [
  { src: "/images/hero/hero-1.webp", alt: "The Hen House" },
  { src: "/images/hero/hero-2.jpg", alt: "Countryside view" },
  { src: "/images/hero/hero-3.jpg", alt: "Interior" },
];

const {
  images = defaultImages,
  pageBackground = "#ffffff",
} = Astro.props;
---

<div class="gallery-slider" id="gallerySlider" style={`--page-bg: ${pageBackground}`}>
  <div class="slider-track" id="sliderTrack">
    {images.map((img, i) => (
      <div class="slide">
        <img src={img.src} alt={img.alt} loading={i === 0 ? "eager" : "lazy"} />
      </div>
    ))}
  </div>
  <div class="slider-counter">
    <span id="currentSlide">1</span> / <span id="totalSlides">{images.length}</span>
  </div>
  <div class="slider-progress">
    <div class="slider-progress-fill" id="progressFill"></div>
  </div>
  <div class="slider-nav">
    <button type="button" class="nav-btn" id="prevBtn" aria-label="Previous slide">
      <svg width="16" height="16" viewBox="0 0 18 18" fill="none">
        <path d="M11 14L6 9L11 4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </button>
    <button type="button" class="nav-btn" id="nextBtn" aria-label="Next slide">
      <svg width="16" height="16" viewBox="0 0 18 18" fill="none">
        <path d="M7 4L12 9L7 14" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </button>
  </div>
</div>

<style>
  .gallery-slider {
    position: relative;
    width: 100%;
    height: 54vh;
    overflow: hidden;
    background: #1a1a1a;
    cursor: grab;
  }

  @media (min-width: 768px) {
    .gallery-slider {
      height: 74vh;
    }
  }
  .gallery-slider:active { cursor: grabbing; }

  .slider-track {
    display: flex;
    height: 100%;
    will-change: transform;
    transition: transform 0.5s cubic-bezier(0.77, 0, 0.175, 1);
  }

  .slide {
    flex: 0 0 100%;
    width: 100%;
    height: 100%;
    overflow: hidden;
    position: relative;
  }

  .slide img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    min-width: 100%;
    min-height: 100%;
    object-fit: cover;
    object-position: center center;
    display: block;
    transform: scale(1.02);
    transition: transform 0.5s cubic-bezier(0.77, 0, 0.175, 1);
  }
  .slide.is-active img {
    transform: scale(1);
    object-position: center center;
  }

  .slider-counter {
    position: absolute;
    top: 18px;
    right: 18px;
    font-size: 12px;
    letter-spacing: 0.06em;
    color: rgba(255,255,255,0.88);
    background: rgba(0,0,0,0.28);
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
    padding: 5px 12px;
    border-radius: 100px;
    line-height: 1;
    z-index: 10;
  }

  .slider-progress {
    position: absolute;
    bottom: 0; left: 0;
    width: 100%; height: 2px;
    background: rgba(255,255,255,0.15);
    z-index: 10;
  }
  .slider-progress-fill {
    height: 100%;
    background: rgba(255,255,255,0.7);
    transition: width 0.5s cubic-bezier(0.77, 0, 0.175, 1);
  }

  .slider-nav {
    position: absolute;
    bottom: 0;
    left: 0;
    z-index: 20;
    background: var(--page-bg, #ffffff);
    border-radius: 0;
    padding: 20px 28px 22px 20px;
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .nav-btn {
    width: 42px;
    height: 42px;
    border-radius: 50%;
    border: 1.5px solid #d4d0c8;
    background: transparent;
    color: #1a1a1a;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.18s ease, border-color 0.18s ease, transform 0.14s ease;
  }
  .nav-btn:hover {
    background: #fff;
    border-color: #a8a49c;
    transform: scale(1.08);
  }
  .nav-btn:active { transform: scale(0.93); }
</style>

<script is:inline>
  (function () {
    const track       = document.getElementById('sliderTrack');
    const slider      = document.getElementById('gallerySlider');
    const prevBtn     = document.getElementById('prevBtn');
    const nextBtn     = document.getElementById('nextBtn');
    const currentEl   = document.getElementById('currentSlide');
    const progFill    = document.getElementById('progressFill');

    const slides = track.querySelectorAll('.slide');
    const total  = slides.length;
    let current  = 0;
    let autoTimer = null;
    const DELAY = 5000;

    function goTo(idx) {
      idx = (idx + total) % total;
      slides[current].classList.remove('is-active');
      current = idx;
      track.style.transform = `translateX(-${current * 100}%)`;
      slides[current].classList.add('is-active');
      currentEl.textContent = current + 1;
      progFill.style.width = ((current + 1) / total * 100) + '%';
    }

    function startAuto() {
      clearInterval(autoTimer);
      autoTimer = setInterval(() => goTo(current + 1), DELAY);
    }

    prevBtn.addEventListener('click', () => { goTo(current - 1); startAuto(); });
    nextBtn.addEventListener('click', () => { goTo(current + 1); startAuto(); });

    let tx = 0;
    slider.addEventListener('touchstart', e => { tx = e.touches[0].clientX; }, { passive: true });
    slider.addEventListener('touchend', e => {
      const d = tx - e.changedTouches[0].clientX;
      if (Math.abs(d) > 40) { goTo(d > 0 ? current + 1 : current - 1); startAuto(); }
    }, { passive: true });

    slider.addEventListener('mouseenter', () => clearInterval(autoTimer));
    slider.addEventListener('mouseleave', () => startAuto());

    goTo(0);
    startAuto();
  })();
</script>
