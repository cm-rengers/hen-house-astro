---
// Square hero stage; overflow clip only at viewport. Controls tile bottom-left (Nordhjem style).
const slides = [
  { src: '/images/hero/hero_gallery_1.jpg', alt: 'The Hen House exterior' },
  { src: '/images/hero/hero_gallery_2.webp', alt: 'Countryside view' },
  { src: '/images/hero/hero_gallery_3.jpg', alt: 'Interior' },
];
---

<div class="hero-gallery" data-hero-slider>
  <div class="hero-gallery-viewport embla__viewport" data-embla-viewport>
    <div class="hero-card-slides embla__container" data-embla-container>
      {slides.map((slide) => (
        <div class="hero-card-slide embla__slide" data-embla-slide>
          <img src={slide.src} alt={slide.alt} width="800" height="800" />
        </div>
      ))}
    </div>
  </div>
  <div class="hero-gallery-controls" aria-label="Slider controls">
    <div class="hero-gallery-controls-tile">
      <button type="button" class="hero-card-prev" data-embla-prev aria-label="Previous slide">
        <span aria-hidden="true">‹</span>
      </button>
      <span class="hero-card-counter" data-embla-counter aria-live="polite">1 / {slides.length}</span>
      <button type="button" class="hero-card-next" data-embla-next aria-label="Next slide">
        <span aria-hidden="true">›</span>
      </button>
    </div>
  </div>
</div>

<script>
  import '../scripts/hero-slider.js';
</script>

<style>
  /* Only viewport clips; wrapper and gallery overflow visible */
  .hero-gallery {
    position: relative;
    overflow: visible;
  }

  .hero-gallery-viewport {
    position: relative;
    width: 100%;
    aspect-ratio: 1 / 1;
    overflow: hidden;
    border-radius: 0;
  }

  .hero-card-slides {
    display: flex;
    height: 100%;
    touch-action: pan-y pinch-zoom;
    user-select: none;
  }

  .hero-card-slide {
    flex: 0 0 100%;
    min-width: 0;
    height: 100%;
  }

  .hero-card-slide img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    border-radius: 0;
  }

  /* Controls tile – bottom-left, outside image (Nordhjem) */
  .hero-gallery-controls {
    position: absolute;
    left: 16px;
    bottom: -22px;
    z-index: 10;
    pointer-events: none;
    border-radius: 0;
  }

  .hero-gallery-controls-tile {
    pointer-events: auto;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 14px;
    height: 74px;
    min-width: 184px;
    padding: 0 18px;
    background: #fff;
    border: 1px solid var(--color-border);
    box-shadow: 0 20px 55px rgba(0, 0, 0, 0.1);
    border-radius: 0;
  }

  .hero-card-prev,
  .hero-card-next {
    width: 36px;
    height: 36px;
    border: none;
    background: transparent;
    cursor: pointer;
    color: var(--color-text-muted);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.5rem;
    line-height: 1;
    transition: color 0.18s ease;
  }

  .hero-card-prev:hover,
  .hero-card-next:hover {
    color: var(--color-text);
  }

  .hero-card-counter {
    font-variant-numeric: tabular-nums;
    font-size: 0.9375rem;
    color: var(--color-text);
  }

  @media (max-width: 767px) {
    .hero-gallery-controls {
      left: 12px;
      bottom: -20px;
    }
  }
</style>
