---
// Sticky header: left logo, center nav, primary CTA "Book now" scrolls to #book.
---

<header class="site-header" id="site-header">
  <div class="site-header-inner">
    <a href="/" class="site-header-logo">THE HEN HOUSE</a>
    <nav class="site-header-nav" aria-label="Main">
      <a href="#gallery" class="site-header-link">Gallery</a>
      <a href="#stay" class="site-header-link">Stay</a>
      <a href="#facilities" class="site-header-link">Facilities</a>
      <a href="#location" class="site-header-link">Location</a>
    </nav>
    <a href="#book" class="site-header-cta">Book now</a>
  </div>
</header>

<script>
  (function () {
    const header = document.getElementById('site-header');
    if (!header) return;
    function updateScroll() {
      if (window.scrollY > 8) {
        header.classList.add('is-scrolled');
      } else {
        header.classList.remove('is-scrolled');
      }
    }
    window.addEventListener('scroll', updateScroll, { passive: true });
    updateScroll();
  })();
</script>
