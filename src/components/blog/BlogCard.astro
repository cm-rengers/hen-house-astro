---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';

interface Props {
  post: CollectionEntry<'blog'>;
  readingTime: number;
}

const { post, readingTime } = Astro.props;
const { title, description, publishDate, heroImage, heroImageAlt, tags } = post.data;
const slug = post.id.replace(/\.(md|mdx)$/, '');
const formattedDate = publishDate.toLocaleDateString('en-GB', {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
});
---

<article class="group flex flex-col bg-[#f9f8f6] overflow-hidden">
  <a
    href={`/blog/${slug}`}
    class="block overflow-hidden relative no-underline"
    style="aspect-ratio: 4/3;"
    aria-label={`Read: ${title}`}
    tabindex="-1"
  >
    <Image
      src={heroImage}
      alt={heroImageAlt}
      width={640}
      height={480}
      class="w-full h-full object-cover transition-transform duration-700 ease-out group-hover:scale-105"
      loading="lazy"
    />
    <div
      class="absolute inset-0 bg-black/0 group-hover:bg-black/10 transition-colors duration-300"
      aria-hidden="true"
    ></div>
  </a>

  <div class="flex flex-col flex-1 p-6 md:p-7">
    <div
      class="flex items-center gap-4 mb-3 text-[#6b6b6b]"
      style="font-size: 0.68rem; letter-spacing: 0.12em; text-transform: uppercase;"
    >
      <time datetime={publishDate.toISOString()}>{formattedDate}</time>
      <span aria-hidden="true">·</span>
      <span>{readingTime} min</span>
    </div>

    <h2 class="mb-2 leading-tight" style="font-family: 'Cormorant Garamond', Georgia, serif; font-weight: 500;">
      <a
        href={`/blog/${slug}`}
        class="text-[#1a1a1a] hover:text-[#6b6b6b] transition-colors duration-200 no-underline"
        style="font-size: clamp(1.2rem, 2.4vw, 1.55rem);"
      >
        {title}
      </a>
    </h2>

    <p class="text-[#6b6b6b] text-sm leading-relaxed mb-5 flex-1">
      {description}
    </p>

    <div class="flex items-end justify-between gap-3 mt-auto pt-4 border-t border-[#e5e2dc]">
      {tags.length > 0 && (
        <ul class="flex flex-wrap gap-2 m-0 p-0 list-none" aria-label="Tags">
          {tags.slice(0, 2).map((tag) => (
            <li>
              <a
                href={`/blog?tag=${encodeURIComponent(tag)}`}
                class="inline-block px-3 py-1 rounded-full text-[10px] tracking-widest uppercase bg-[#f0ede8] text-[#6b6b6b] hover:bg-[#1a1a1a] hover:text-white transition-all duration-200 no-underline"
              >
                {tag}
              </a>
            </li>
          ))}
        </ul>
      )}

      <a
        href={`/blog/${slug}`}
        class="shrink-0 text-xs tracking-widest uppercase text-[#1a1a1a] flex items-center gap-1 hover:gap-2 transition-all duration-200 no-underline"
        aria-label={`Read full article: ${title}`}
      >
        Read <span aria-hidden="true">↗</span>
      </a>
    </div>
  </div>
</article>
