---
interface FAQ {
  question: string;
  answer: string;
}

interface Props {
  faqs: FAQ[];
  heading?: string;
}

const {
  faqs,
  heading = 'Frequently asked',
} = Astro.props;
---

{faqs.length > 0 && (
  <section class="py-16 md:py-20 border-t border-[#e5e2dc]" aria-labelledby="faq-heading">
    <div class="max-w-[1200px] mx-auto px-6 md:px-10 lg:px-14">
      <h2
        id="faq-heading"
        class="mb-10 md:mb-12 leading-tight"
        style="
          font-family: 'Cormorant Garamond', Georgia, serif;
          font-weight: 500;
          font-size: clamp(1.7rem, 3.5vw, 2.75rem);
          letter-spacing: -0.01em;
        "
      >
        {heading}
      </h2>

      <dl class="divide-y divide-[#e5e2dc]">
        {faqs.map((faq) => (
          <div>
            <details class="group py-5" name="faq-group">
              <summary class="flex items-center justify-between gap-4 cursor-pointer list-none select-none">
                <dt class="text-[#1a1a1a] font-normal leading-snug pr-4" style="font-size: clamp(0.95rem, 1.8vw, 1.05rem);">
                  {faq.question}
                </dt>
                <span
                  class="shrink-0 w-5 h-5 flex items-center justify-center text-[#6b6b6b] transition-transform duration-200 group-open:rotate-45"
                  aria-hidden="true"
                  style="font-size: 1.2rem; line-height: 1;"
                >
                  +
                </span>
              </summary>
              <dd class="mt-3 pb-1 text-[#6b6b6b] leading-relaxed" style="font-size: 0.9rem;">
                {faq.answer}
              </dd>
            </details>
          </div>
        ))}
      </dl>
    </div>
  </section>
)}

<style>
  details[open] > summary > span {
    transform: rotate(45deg);
  }
</style>
