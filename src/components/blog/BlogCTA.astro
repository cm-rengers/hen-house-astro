---
interface Props {
  headline?: string;
  subheading?: string;
  variant?: 'standard' | 'contact';
}

const {
  headline = 'Ready to escape to Cumbria?',
  subheading = 'Check availability and book your stay at The Hen House, with dog-friendly space, EV charging and easy access from the M6.',
  variant = 'standard',
} = Astro.props;
---

<section class="blog-cta" aria-labelledby="blog-cta-heading">
  <div class="blog-container blog-cta-inner">
    <div class="blog-cta-copy">
      <p class="blog-kicker">Book your stay</p>
      <h2 id="blog-cta-heading">{headline}</h2>
      <p>{subheading}</p>
    </div>
    <div class="blog-cta-actions">
      {variant === 'standard' ? (
        <>
          <a class="blog-button blog-button-primary" href="https://www.airbnb.co.uk/rooms/1477403609287112139" target="_blank" rel="noopener noreferrer">Airbnb</a>
          <a class="blog-button blog-button-secondary" href="https://www.booking.com/hotel/gb/the-hen-house-westmorland-and-furness.en-gb.html" target="_blank" rel="noopener noreferrer">Booking.com</a>
        </>
      ) : (
        <a class="blog-button blog-button-primary" href="mailto:hello@thehenhousecumbria.co.uk">Get in touch</a>
      )}
    </div>
  </div>
</section>
