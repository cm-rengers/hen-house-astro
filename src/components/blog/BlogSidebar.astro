---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';

interface Props {
  allPosts: CollectionEntry<'blog'>[];
  currentSlug?: string;
}

const { allPosts, currentSlug } = Astro.props;
const toSlug = (id: string) => id.replace(/\.(md|mdx)$/, '');
const popular = allPosts
  .filter((post) => !post.data.draft && toSlug(post.id) !== currentSlug)
  .sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime())
  .slice(0, 4);
const allTags = [...new Set(allPosts.flatMap((post) => post.data.tags))].sort();
---

<aside class="hidden lg:block w-[300px] shrink-0" aria-label="Blog sidebar">
  <div class="sticky top-8 flex flex-col gap-10">
    {popular.length > 0 && (
      <section aria-labelledby="sidebar-popular">
        <h3 id="sidebar-popular" class="text-[10px] tracking-[0.2em] uppercase text-[#6b6b6b] mb-5 pb-3 border-b border-[#e5e2dc]">
          Popular posts
        </h3>
        <ul class="flex flex-col gap-5 m-0 p-0 list-none">
          {popular.map((post) => {
            const slug = toSlug(post.id);
            return (
              <li class="group flex gap-3">
                <a
                  href={`/blog/${slug}`}
                  class="block shrink-0 overflow-hidden no-underline"
                  style="width: 68px; height: 52px;"
                  aria-label={`Read: ${post.data.title}`}
                  tabindex="-1"
                >
                  <Image
                    src={post.data.heroImage}
                    alt={post.data.heroImageAlt}
                    width={136}
                    height={104}
                    class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110"
                    loading="lazy"
                  />
                </a>
                <div class="flex-1 min-w-0">
                  <h4 style="font-family: 'Cormorant Garamond', Georgia, serif; font-weight: 500; font-size: 0.95rem; line-height: 1.3;">
                    <a href={`/blog/${slug}`} class="text-[#1a1a1a] hover:text-[#6b6b6b] transition-colors duration-200 line-clamp-2 no-underline">
                      {post.data.title}
                    </a>
                  </h4>
                  <time datetime={post.data.publishDate.toISOString()} class="text-[#6b6b6b]" style="font-size: 0.65rem; letter-spacing: 0.1em; text-transform: uppercase;">
                    {post.data.publishDate.toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: 'numeric' })}
                  </time>
                </div>
              </li>
            );
          })}
        </ul>
      </section>
    )}

    {allTags.length > 0 && (
      <section aria-labelledby="sidebar-categories">
        <h3 id="sidebar-categories" class="text-[10px] tracking-[0.2em] uppercase text-[#6b6b6b] mb-5 pb-3 border-b border-[#e5e2dc]">
          Topics
        </h3>
        <ul class="flex flex-wrap gap-2 m-0 p-0 list-none">
          {allTags.map((tag) => (
            <li>
              <a
                href={`/blog?tag=${encodeURIComponent(tag)}`}
                class="inline-block px-3 py-1 rounded-full text-[10px] tracking-widest uppercase bg-[#f0ede8] text-[#6b6b6b] hover:bg-[#1a1a1a] hover:text-white transition-all duration-200 no-underline"
              >
                {tag}
              </a>
            </li>
          ))}
        </ul>
      </section>
    )}

    <section class="bg-[#f9f8f6] p-6 border border-[#e5e2dc]" aria-labelledby="sidebar-book">
      <p class="text-[10px] tracking-[0.2em] uppercase text-[#6b6b6b] mb-2">
        Cumbria, near the M6
      </p>
      <h3 id="sidebar-book" class="mb-3 leading-tight" style="font-family: 'Cormorant Garamond', Georgia, serif; font-weight: 500; font-size: 1.35rem;">
        The Hen House
      </h3>
      <p class="text-[#6b6b6b] text-xs leading-relaxed mb-5">
        Dog friendly · EV charging · Lake District access · Fenced paddock
      </p>
      <a
        href="https://www.airbnb.co.uk/rooms/1477403609287112139"
        target="_blank"
        rel="noopener noreferrer"
        class="block w-full text-center py-3 px-4 bg-[#1a1a1a] text-white text-[10px] tracking-widest uppercase hover:bg-[#2d2d2d] transition-colors duration-200 no-underline"
      >
        Check availability ↗
      </a>
    </section>
  </div>
</aside>
