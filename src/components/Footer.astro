---
const currentYear = new Date().getFullYear();
---

<footer class="footer">
  <div class="footer-inner">

    <!-- Brand -->
    <div class="footer-brand">
      <a href="/" class="footer-logo">The Hen House</a>
      <p class="footer-tagline">A rural retreat in the heart of Cumbria. Idyllic surroundings, unhurried stays, and a warm welcome waiting for you.</p>
    </div>

    <!-- Navigation -->
    <div>
      <p class="footer-col-title">Explore</p>
      <ul class="footer-nav">
        <li><a href="#stay">About</a></li>
        <li><a href="#facilities">Amenities</a></li>
        <li><a href="#gallery">Gallery</a></li>
        <li><a href="#location">Location</a></li>
        <li><a href="#book">Booking</a></li>
        <li><a href="#faq">FAQ</a></li>
      </ul>
    </div>

    <!-- Contact -->
    <div>
      <p class="footer-col-title">Contact</p>
      <div class="footer-contact">
        <a href="mailto:hello@thehenhousecumbria.co.uk">hello@thehenhousecumbria.co.uk</a>
        <address class="footer-address">
          The Hen House<br>
          Old Hutton<br>
          LA8 0NH
        </address>
      </div>
    </div>

  </div>

  <!-- Bottom bar -->
  <div class="footer-bottom">
    <p class="footer-copy">© {currentYear} The Hen House Cumbria. All rights reserved.</p>
