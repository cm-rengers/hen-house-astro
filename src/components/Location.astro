              <path fill="#B8976A" d="M83.11,17a3.11,3.11,0,0,0-2.18.14,4.09,4.09,0,0,0-1.65,1.65c-.21.32.3.62.52.3.76-1.14,1.71-1.93,3.16-1.52A.3.3,0,0,0,83.11,17Z"/>
