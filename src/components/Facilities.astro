---
export interface Props {
  heading?: string;
  subheading?: string;
}

const { heading = "Facilities", subheading = "Enjoy modern comforts in a countryside setting — everything you need for a relaxed and effortless stay." } = Astro.props;

const gold = 'currentColor';
const facilities = [
  { label: "Self check-in", svg: `<rect x="9" y="2" width="6" height="20" rx="3"/><line x1="15" y1="9" x2="22" y2="9"/><path d="M22 9 Q23.5 9 23.5 10.5 L23.5 13"/><circle cx="12" cy="15" r="1.2"/><path d="M11.3 16.2 L12.7 16.2 L12.4 19 L11.6 19 Z"/>` },
  { label: "Oven", svg: `<rect x="3" y="3" width="18" height="18" rx="1.5"/><line x1="3" y1="8" x2="21" y2="8"/><circle cx="7" cy="5.5" r="1.2"/><circle cx="12" cy="5.5" r="1.2"/><circle cx="17" cy="5.5" r="1.2"/><rect x="6" y="10.5" width="12" height="8" rx="1"/><line x1="7" y1="22" x2="17" y2="22"/>` },
  { label: "Wardrobe", svg: `<rect x="2" y="3" width="20" height="18" rx="1.5"/><line x1="12" y1="3" x2="12" y2="21"/><path d="M9 11.5 Q10.5 11.5 10.5 12 Q10.5 12.5 9 12.5"/><path d="M15 11.5 Q13.5 11.5 13.5 12 Q13.5 12.5 15 12.5"/><path d="M7 7 Q7 6 8 6 Q9 6 9 7 L6 10 L10 10"/><path d="M17 7 Q17 6 16 6 Q15 6 15 7 L18 10 L14 10"/>` },
  { label: "Microwave", svg: `<rect x="2" y="6" width="20" height="13" rx="1.5"/><rect x="4" y="8.5" width="12" height="8" rx="1"/><line x1="18" y1="8.5" x2="20" y2="8.5"/><circle cx="19" cy="11" r="0.8" fill="${gold}" stroke="none"/><circle cx="19" cy="13.5" r="0.8" fill="${gold}" stroke="none"/><circle cx="19" cy="16" r="0.8" fill="${gold}" stroke="none"/><path d="M6.5 13 Q7.5 11.5 8.5 13 Q9.5 14.5 10.5 13" stroke-width="1"/>` },
  { label: "Fast WiFi", svg: `<path d="M1.5 8.5 C5.2 4.8 10.3 3 12 3 C13.7 3 18.8 4.8 22.5 8.5"/><path d="M5 12 C7.2 9.8 9.8 8.5 12 8.5 C14.2 8.5 16.8 9.8 19 12"/><path d="M8.5 15.5 C9.8 14.2 10.9 13.5 12 13.5 C13.1 13.5 14.2 14.2 15.5 15.5"/><circle cx="12" cy="19.5" r="1.2" fill="${gold}" stroke="none"/>` },
  { label: "Towels", svg: `<line x1="4" y1="4" x2="20" y2="4"/><line x1="4" y1="2.5" x2="4" y2="5.5"/><line x1="20" y1="2.5" x2="20" y2="5.5"/><path d="M8 4 L8 17 Q8 20 12 20 Q16 20 16 17 L16 4"/><line x1="8" y1="9" x2="16" y2="9"/>` },
  { label: "Double bed & two twins", svg: `<path d="M3 17 L3 9 Q3 8 4 8 L20 8 Q21 8 21 9 L21 17"/><line x1="2" y1="17" x2="22" y2="17"/><line x1="3" y1="8" x2="3" y2="5"/><line x1="21" y1="8" x2="21" y2="5"/><line x1="3" y1="5" x2="21" y2="5"/><rect x="5" y="10" width="5.5" height="4" rx="1"/><rect x="13.5" y="10" width="5.5" height="4" rx="1"/><line x1="12" y1="8" x2="12" y2="17" stroke-dasharray="1.5 1.5" stroke-width="0.8"/><line x1="4" y1="17" x2="4" y2="20"/><line x1="20" y1="17" x2="20" y2="20"/>` },
  { label: "Tea & coffee", svg: `<path d="M6 10 L7.5 19 Q7.5 20 9 20 L15 20 Q16.5 20 16.5 19 L18 10 Z"/><path d="M18 13 Q22 13 22 15.5 Q22 18 18 18"/><path d="M5 21 Q12 23 19 21"/><path d="M9 7.5 Q8 5.5 9 4" stroke-width="1"/><path d="M12 8 Q11 5.5 12 3.5" stroke-width="1"/><path d="M15 7.5 Q14 5.5 15 4" stroke-width="1"/>` },
  { label: "Free parking", svg: `<rect x="3" y="3" width="18" height="18" rx="2.5"/><path d="M9 7 L9 17"/><path d="M9 7 L14 7 Q17 7 17 10.5 Q17 14 14 14 L9 14"/>` },
  { label: "Car charger", sublabel: "additional charge", svg: `<path d="M1 13 L3 8 Q3.5 6.5 5 6.5 L15 6.5 Q16.5 6.5 17 8 L19 13 Q19.5 13.5 19 14 L19 17 Q19 18 18 18 L2 18 Q1 18 1 17 L1 14 Q0.5 13.5 1 13 Z"/><circle cx="5.5" cy="18" r="2"/><circle cx="14.5" cy="18" r="2"/><path d="M4.5 12.5 L6 8.5 L14 8.5 L15.5 12.5 Z"/><line x1="19" y1="12" x2="22" y2="12"/><line x1="22" y1="10" x2="22" y2="14"/><line x1="21" y1="9" x2="21" y2="10"/><line x1="23" y1="9" x2="23" y2="10"/><path d="M10.5 10.5 L9 13 L10.5 13 L8.5 16 L13 12.5 L11 12.5 Z" fill="${gold}" stroke="none"/>` },
  { label: "Toiletries", svg: `<rect x="7" y="11" width="10" height="11" rx="1.5"/><rect x="10" y="7" width="4" height="5" rx="0.5"/><rect x="8.5" y="5" width="7" height="3" rx="1"/><line x1="15.5" y1="6.5" x2="18.5" y2="6.5"/><line x1="18.5" y1="6.5" x2="18.5" y2="9"/><line x1="9.5" y1="15" x2="14.5" y2="15" stroke-width="0.9"/><line x1="9.5" y1="17" x2="13" y2="17" stroke-width="0.9"/>` },
  { label: "Power shower", svg: `<path d="M3 11 L3 17 Q3 20 6 20 L18 20 Q21 20 21 17 L21 11 Z"/><line x1="2" y1="11" x2="22" y2="11"/><line x1="8" y1="11" x2="8" y2="7"/><line x1="6" y1="7" x2="10" y2="7"/><line x1="8" y1="5" x2="8" y2="9"/><path d="M8 8 Q11 8 11 11"/><line x1="5" y1="20" x2="5" y2="23"/><line x1="19" y1="20" x2="19" y2="23"/><path d="M14 14.5 Q14 13 15 13 Q16 13 16 14.5 Q16 16 15 16 Q14 16 14 14.5 Z"/>` },
  { label: "Hair dryer", svg: `<path d="M8 7 Q8 4 12 4 L18 4 Q21 4 21 8 Q21 12 18 12 L12 12 Q8 12 8 9 Z"/><path d="M8 7.5 L4 9 L4 11 L8 10.5"/><path d="M13 12 L12 19 Q12 20.5 13.5 20.5 Q15 20.5 15 19 L14 12"/><line x1="2" y1="8" x2="4" y2="9"/><line x1="2" y1="10" x2="4" y2="10"/><line x1="2" y1="12" x2="4" y2="11"/><line x1="16" y1="5.5" x2="16" y2="10.5" stroke-width="0.9"/><line x1="18" y1="5" x2="18" y2="11" stroke-width="0.9"/>` },
  { label: "Iron", svg: `<path d="M2 17 L18 17 Q23 17 23 14 Q23 11 18 11 L2 11 Z"/><path d="M2 11 Q1 11 1 14 Q1 17 2 17"/><path d="M5 11 Q5 6 9 5 L15 5 Q18 5 18 11"/><line x1="9" y1="5" x2="15" y2="5"/><line x1="7" y1="14" x2="7" y2="17" stroke-width="0.9"/><line x1="11" y1="13.5" x2="11" y2="17" stroke-width="0.9"/><line x1="15" y1="13.5" x2="15" y2="17" stroke-width="0.9"/>` },
  { label: "Dishwasher", svg: `<rect x="4" y="2" width="16" height="20" rx="1.5"/><rect x="6" y="9" width="12" height="11" rx="1"/><line x1="6" y1="7" x2="18" y2="7"/><circle cx="9" cy="5.5" r="0.8" fill="${gold}" stroke="none"/><circle cx="12" cy="5.5" r="0.8" fill="${gold}" stroke="none"/><circle cx="15" cy="5.5" r="0.8" fill="${gold}" stroke="none"/><line x1="9" y1="7.8" x2="15" y2="7.8"/><line x1="9" y1="11" x2="9" y2="18"/><line x1="12" y1="11" x2="12" y2="18"/><line x1="15" y1="11" x2="15" y2="18"/><line x1="7.5" y1="18" x2="16.5" y2="18"/>` },
  { label: "Close to M6", svg: `<line x1="6" y1="2" x2="6" y2="22"/><line x1="18" y1="2" x2="18" y2="22"/><line x1="12" y1="2" x2="12" y2="6"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="16" x2="12" y2="20"/>` },
];

const svgAttrs = 'viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round" xmlns="http://www.w3.org/2000/svg"';
---

<hr class="facilities-divider" />
<section class="facilities-section">
  <h2 class="facilities-title">{heading}</h2>
  <p class="facilities-sub">{subheading}</p>
  <div class="facilities-grid">
    {
      facilities.map(({ label, sublabel, svg }) => (
        <div class="facility-item">
          <div class="facility-icon" set:html={`<svg ${svgAttrs}>${svg}</svg>`} />
          <span class="facility-label">{label}</span>
          {sublabel ? <span class="facility-sublabel">{sublabel}</span> : null}
        </div>
      ))
    }
  </div>
</section>

<style>
  .facilities-divider {
    border: none;
    border-top: 1px solid #e8e4de;
    margin: 0;
  }

  .facilities-section {
    padding: 52px 24px 64px;
    text-align: center;
  }

  .facilities-title {
    font-family: var(--font-serif, 'Playfair Display', Georgia, serif);
    font-size: clamp(36px, 5vw, 52px);
    color: #1a1a1a;
    margin: 0 0 12px;
    font-weight: 700;
  }

  .facilities-sub {
    font-family: var(--font-sans, 'Inter', system-ui, sans-serif);
    font-weight: 400;
    font-size: clamp(14px, 1.5vw, 15px);
    color: #777;
    margin: 0 auto 40px;
    max-width: 560px;
    line-height: 1.5;
  }

  .facilities-grid {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    row-gap: 52px;
    column-gap: 20px;
    max-width: 900px;
    margin: 0 auto;
  }

  .facility-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
  }

  .facility-icon {
    width: 36px;
    height: 36px;
    color: #c8a97e;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .facility-icon :global(svg) {
    width: 36px;
    height: 36px;
    display: block;
  }

  .facility-label {
    font-size: 13px;
    color: #444;
    text-align: center;
    line-height: 1.4;
  }

  .facility-sublabel {
    font-size: 11px;
    color: #aaa;
  }

  @media (max-width: 900px) {
    .facilities-grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  @media (max-width: 640px) {
    .facilities-section {
      padding: 40px 16px 48px;
    }

    .facilities-grid {
      grid-template-columns: repeat(3, 1fr);
      row-gap: 40px;
      column-gap: 16px;
    }
  }

  @media (max-width: 420px) {
    .facilities-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>
